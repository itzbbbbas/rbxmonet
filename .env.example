# Roblox Open Cloud API key (Creator Hub → Open Cloud → API Keys).
# Scopes:
#   game-pass:read, game-pass:write
#   developer-product:read, developer-product:write
#   legacy-universe.badge:read, legacy-universe.badge:write,
#   legacy-universe.badge:manage-and-spend-robux
#   legacy-asset:manage   (icon uploads)
RBXMONET_API_KEY=

# Skip diff viewer in `rbxmonet sync` (auto-confirm all changes).
# CLI flag `-a` / `--auto-confirm` takes precedence over this.
# RBXMONET_AUTO_CONFIRM=true
