[metadata]
universe_id = 1234                         # numeric Roblox universe id
discount_prefix = "💲{}% OFF💲 "           # {} is substituted with the discount percent
name_filters = []                          # regex list applied to remote names on download

[icons]
bleed = true                               # alpha-bleed icons before upload (fixes black halos)
dir = "icons"                              # directory icons will be downloaded into (reserved)

[codegen]
output = "src/ReplicatedFirst/monets.luau" # required; omit to skip Luau generation
# style = "flat"                           # "flat" (default) or "nested"
# typescript = false                       # also emit <output>.d.ts sidecar

[codegen.paths]
# passes   = "Gamepasses"                  # rename / re-nest section roots in Luau output
# products = "Products"
# badges   = "Items.Badges"

[codegen.extra]
# "Gamepasses.legacy_vip" = 1234567        # inject id leaves for assets rbxmonet doesn't track

